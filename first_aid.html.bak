{% extends "base.html" %}
{% block title %}First Aid Assistant — ResQAI{% endblock %}

{% block content %}
<div class="container py-4">

  <!-- Header -->
  <div class="d-flex align-items-center gap-3 mb-4">
    <div class="resq-feature-icon-lg bg-success-subtle">
      <i class="bi bi-heart-pulse-fill text-success fs-2"></i>
    </div>
    <div>
      <h2 class="fw-bold mb-0">First Aid Assistant</h2>
      <p class="text-muted small mb-0">AI-powered first aid instructions — describe the emergency for instant guidance</p>
    </div>
  </div>

  <div class="alert resq-alert-warning mb-4">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <strong>Call 911 first</strong> in any life-threatening situation. AI guidance does not replace professional medical care.
  </div>

  <div class="row g-4">
    <!-- AI Query Panel -->
    <div class="col-lg-5">
      <div class="resq-card p-4 h-100">
        <h5 class="fw-bold text-white mb-3"><i class="bi bi-robot me-2 text-success"></i>AI First Aid Lookup</h5>
        <p class="text-secondary small mb-3">Describe the medical situation and get step-by-step first aid guidance.</p>

        <div class="mb-3">
          <label class="form-label text-muted small fw-semibold">Emergency Situation</label>
          <textarea id="situationInput" class="form-control resq-input" rows="4" placeholder="e.g., A person has collapsed and is not breathing... A child is choking on food..."></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label text-muted small fw-semibold">Or select a common scenario:</label>
          <div class="d-grid gap-2">
            <button class="btn btn-sm resq-scenario-btn text-start" data-scenario="Someone is having a cardiac arrest and is unconscious with no pulse">
              <i class="bi bi-heart-fill text-danger me-2"></i>Cardiac Arrest / CPR
            </button>
            <button class="btn btn-sm resq-scenario-btn text-start" data-scenario="A person is choking and cannot breathe or speak">
              <i class="bi bi-lungs-fill text-warning me-2"></i>Choking
            </button>
            <button class="btn btn-sm resq-scenario-btn text-start" data-scenario="Someone has a deep wound with heavy bleeding that won't stop">
              <i class="bi bi-droplet-fill text-danger me-2"></i>Severe Bleeding
            </button>
            <button class="btn btn-sm resq-scenario-btn text-start" data-scenario="A person has a suspected broken bone or fracture in the leg">
              <i class="bi bi-bandaid-fill text-info me-2"></i>Fracture / Broken Bone
            </button>
            <button class="btn btn-sm resq-scenario-btn text-start" data-scenario="Someone has been severely burned by fire or hot liquid">
              <i class="bi bi-fire text-warning me-2"></i>Severe Burns
            </button>
            <button class="btn btn-sm resq-scenario-btn text-start" data-scenario="A person is having a seizure and shaking uncontrollably">
              <i class="bi bi-activity text-success me-2"></i>Seizure
            </button>
            <button class="btn btn-sm resq-scenario-btn text-start" data-scenario="Someone is showing signs of a stroke: face drooping, arm weakness, speech difficulty">
              <i class="bi bi-brain text-purple me-2"></i>Stroke
            </button>
            <button class="btn btn-sm resq-scenario-btn text-start" data-scenario="A person is having a severe allergic reaction with difficulty breathing (anaphylaxis)">
              <i class="bi bi-shield-x text-danger me-2"></i>Anaphylaxis / Allergic Reaction
            </button>
          </div>
        </div>

        <button id="getGuidanceBtn" class="btn btn-success w-100">
          <span id="guidanceBtnText"><i class="bi bi-search-heart me-2"></i>Get First Aid Guidance</span>
          <span id="guidanceBtnSpinner" class="d-none"><span class="spinner-border spinner-border-sm me-1"></span>Generating guidance...</span>
        </button>
      </div>
    </div>

    <!-- Guidance Output -->
    <div class="col-lg-7">
      <div class="resq-card p-4 h-100">
        <h5 class="fw-bold text-white mb-3"><i class="bi bi-clipboard2-pulse me-2 text-success"></i>First Aid Instructions</h5>
        <div id="guidanceOutput">
          <div class="resq-empty-state text-center py-5">
            <i class="bi bi-heart-pulse text-success fs-1 d-block mb-3 opacity-50"></i>
            <p class="text-muted">Select a scenario or describe a situation to receive detailed first aid instructions.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Static First Aid Reference Cards -->
  <div class="mt-5">
    <h4 class="fw-bold mb-4 text-white"><i class="bi bi-bookmark-star me-2 text-success"></i>Quick Reference Guides</h4>
    <div class="row g-4">

      <div class="col-md-6" id="cpr">
        <div class="resq-card p-4">
          <h6 class="fw-bold text-success mb-3"><i class="bi bi-heart-pulse-fill me-2"></i>CPR — Adult</h6>
          <ol class="text-secondary small mb-0">
            <li>Ensure scene safety. Call 911 or have someone call.</li>
            <li>Check for responsiveness — tap shoulder, shout "Are you okay?"</li>
            <li>If unresponsive and not breathing normally, begin CPR.</li>
            <li>Place heel of hand on center of chest. Interlock fingers.</li>
            <li>Push hard and fast: <strong>100–120 compressions/min</strong>, 2 inches deep.</li>
            <li>If trained: Give 2 rescue breaths after every 30 compressions.</li>
            <li>Use an AED as soon as one is available.</li>
            <li>Continue until EMS arrives or the person recovers.</li>
          </ol>
        </div>
      </div>

      <div class="col-md-6">
        <div class="resq-card p-4">
          <h6 class="fw-bold text-warning mb-3"><i class="bi bi-droplet-fill me-2"></i>Severe Bleeding Control</h6>
          <ol class="text-secondary small mb-0">
            <li>Call 911 immediately.</li>
            <li>Put on gloves or use a barrier (plastic bag) if available.</li>
            <li>Apply firm, direct pressure using a clean cloth or bandage.</li>
            <li>Do NOT remove the cloth — add more on top if soaked through.</li>
            <li>Apply a tourniquet for limb wounds if bleeding is life-threatening.</li>
            <li>Elevate the injured area above heart level if possible.</li>
            <li>Keep the person warm and calm to reduce shock risk.</li>
            <li>Monitor until EMS arrives.</li>
          </ol>
        </div>
      </div>

      <div class="col-md-6">
        <div class="resq-card p-4">
          <h6 class="fw-bold text-info mb-3"><i class="bi bi-lungs-fill me-2"></i>Choking — Heimlich Maneuver</h6>
          <ol class="text-secondary small mb-0">
            <li>Ask: "Are you choking?" — If they can cough, encourage coughing.</li>
            <li>If unable to cough/speak: Stand behind them, lean them forward.</li>
            <li>Give 5 firm back blows between shoulder blades.</li>
            <li>Give 5 abdominal thrusts (Heimlich): make a fist above navel, pull sharply inward and upward.</li>
            <li>Alternate back blows and abdominal thrusts until object is cleared.</li>
            <li>If person becomes unconscious, begin CPR and call 911.</li>
          </ol>
        </div>
      </div>

      <div class="col-md-6">
        <div class="resq-card p-4">
          <h6 class="fw-bold text-danger mb-3"><i class="bi bi-fire me-2"></i>Burns — First Aid</h6>
          <ol class="text-secondary small mb-0">
            <li>Remove the person from the source of heat or chemical.</li>
            <li>Cool burn under <strong>cool running water for 20 minutes</strong> — do NOT use ice.</li>
            <li>Remove jewelry/clothing near the burn (if not stuck to skin).</li>
            <li>Cover with a loose, non-fluffy material (cling film or a clean bag).</li>
            <li>Do NOT apply butter, toothpaste, or any creams.</li>
            <li>For chemical burns: brush off dry chemicals, flush with water.</li>
            <li>Seek medical attention for all burns larger than 3 inches.</li>
          </ol>
        </div>
      </div>

    </div>
  </div>
</div>
{% endblock %}

{% block extra_scripts %}
<script>
const situationInput = document.getElementById('situationInput');
const getGuidanceBtn = document.getElementById('getGuidanceBtn');
const guidanceBtnText = document.getElementById('guidanceBtnText');
const guidanceBtnSpinner = document.getElementById('guidanceBtnSpinner');
const guidanceOutput = document.getElementById('guidanceOutput');

document.querySelectorAll('.resq-scenario-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    situationInput.value = btn.dataset.scenario;
    situationInput.focus();
  });
});

getGuidanceBtn.addEventListener('click', async () => {
  const situation = situationInput.value.trim();
  if (!situation) {
    situationInput.classList.add('is-invalid');
    return;
  }
  situationInput.classList.remove('is-invalid');

  guidanceBtnText.classList.add('d-none');
  guidanceBtnSpinner.classList.remove('d-none');
  getGuidanceBtn.disabled = true;

  guidanceOutput.innerHTML = `<div class="text-center py-4"><div class="spinner-border text-success"></div><p class="text-muted mt-2 small">AI is generating first aid instructions...</p></div>`;

  try {
    const res = await fetch('/api/first-aid', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({situation})
    });
    const data = await res.json();
    if (data.guidance) {
      guidanceOutput.innerHTML = `
        <div class="resq-guidance-box">
          <div class="d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-robot text-success"></i>
            <small class="text-muted">AI-generated guidance — verify with medical professionals</small>
          </div>
          <div class="resq-guidance-text">${data.guidance.replace(/\n/g, '<br>')}</div>
        </div>
        <div class="alert resq-alert-info mt-3 small">
          <i class="bi bi-info-circle me-1"></i>This AI guidance is for informational purposes. Always follow advice from trained medical professionals and EMS.
        </div>`;
    } else {
      guidanceOutput.innerHTML = `<div class="alert alert-danger">${data.error || 'An error occurred.'}</div>`;
    }
  } catch (e) {
    guidanceOutput.innerHTML = `<div class="alert alert-danger"><i class="bi bi-wifi-off me-2"></i>Network error. Please try again.</div>`;
  } finally {
    guidanceBtnText.classList.remove('d-none');
    guidanceBtnSpinner.classList.add('d-none');
    getGuidanceBtn.disabled = false;
  }
});

situationInput.addEventListener('input', () => situationInput.classList.remove('is-invalid'));
</script>
{% endblock %}
